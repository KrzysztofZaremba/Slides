# Step 3: compute the critical value for 95% CI
alpha=0.05
t_critical=qt(1-alpha/2, df=n-2)
t_critical
# Step 4: compute the margin of error
margin_of_error = t_critical * sqrt(sigma^2 * (1 + 1/n + (x0 - mx)^2 / Sxx))
margin_of_error
