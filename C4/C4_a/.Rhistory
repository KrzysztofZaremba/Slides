library(tidyverse)
All_data <- read.csv("C:/Users/kzysi/Dropbox/Itam_teaching/Data/In_class_task2/Data/Raw_data/restaurant_data.csv")
# ---- Select and rename variables ----
# Keep a manageable set: mix of numeric and binary predictors
vars <- c("Name", "Location", "Rating", "Seating.Capacity", "Average.Meal.Price",
"Marketing.Budget", "Chef.Experience.Years", "Number.of.Reviews",
"Parking.Availability", "Weekend.Reservations", "Revenue")
All_data <- All_data %>% select(all_of(vars))
# Rename for cleaner column names
All_data <- All_data %>% rename(
RestaurantID       = Name,
SeatingCapacity    = Seating.Capacity,
AvgMealPrice       = Average.Meal.Price,
MarketingBudget    = Marketing.Budget,
ChefExperience     = Chef.Experience.Years,
NumberOfReviews    = Number.of.Reviews,
Parking            = Parking.Availability,
WeekendReservations = Weekend.Reservations
)
# ---- Convert categorical variables to 0/1 ----
# Parking: 1 = Yes, 0 = No
All_data$Parking <- ifelse(All_data$Parking == "Yes", 1, 0)
# Location: create dummy for Downtown (1 = Downtown, 0 = other)
All_data$Downtown <- ifelse(All_data$Location == "Downtown", 1, 0)
# Drop the original Location column (students will use Downtown dummy)
All_data <- All_data %>% select(-Location)
# Verify no missing values
cat("Missing values per column:\n")
print(colSums(is.na(All_data)))
# ---- Revenue in thousands (cleaner numbers) ----
All_data$Revenue <- round(All_data$Revenue / 1000, 2)  # Revenue in thousands of dollars
cat("\nDataset dimensions:", dim(All_data), "\n")
cat("Variable names:", paste(names(All_data), collapse = ", "), "\n")
summary(All_data)
# ---- Create 15 student subsets ----
set.seed(5678)
for (i in 1:15) {
sample_data <- All_data %>% sample_n(5000, replace = FALSE)
save(sample_data, file = paste0(
"C:/Users/kzysi/Dropbox/Itam_teaching/Data/In_class_task2/Data/Prepared_data/student_data_", i, ".Rda"
))
}
# ---- Compute answer key for all 15 groups ----
path <- "C:/Users/kzysi/Dropbox/Itam_teaching/Data/In_class_task2/Data/Prepared_data/"
results_list <- list()
for (i in 1:15) {
load(paste0(path, "student_data_", i, ".Rda"))
r2_vals    <- c()
coef_list  <- list()
pred_vals  <- c()
predictors <- setdiff(names(sample_data), c("RestaurantID", "Revenue"))
for (var in predictors) {
f <- as.formula(paste("Revenue ~", var))
m <- lm(f, data = sample_data)
r2_vals[var]   <- summary(m)$r.squared
coef_list[[var]] <- coef(m)
# Prediction at median (numeric) or mode (binary)
binary_vars <- c("Parking", "Downtown")
if (var %in% binary_vars) {
mode_val <- as.numeric(names(sort(table(sample_data[[var]]), decreasing = TRUE))[1])
newdat   <- setNames(data.frame(mode_val), var)
pred_vals[var] <- predict(m, newdat)
} else if (is.numeric(sample_data[[var]])) {
val    <- median(sample_data[[var]], na.rm = TRUE)
newdat <- setNames(data.frame(val), var)
pred_vals[var] <- predict(m, newdat)
}
}
best_var <- names(which.max(r2_vals))
results_list[[i]] <- tibble(
dataset      = i,
best_var     = best_var,
best_r2      = round(r2_vals[best_var], 4),
coefficients = paste(names(coef_list[[best_var]]),
round(coef_list[[best_var]], 3),
collapse = "; "),
pred_at_median = round(pred_vals[best_var], 3)
)
}
results_df <- bind_rows(results_list)
print(results_df, n = 15)
