library(tidyverse)
All_data <- read.csv("C:/Users/kzysi/Dropbox/Itam_teaching/Data/In_class_task1/Data/Raw_data/WA_Fn-UseC_-Telco-Customer-Churn.csv")
#Variables to keep:
vars=c("customerID","gender","SeniorCitizen","tenure","PhoneService","StreamingTV",  # gender renamed to Male below
"StreamingMovies","PaperlessBilling","MonthlyCharges","TotalCharges","Churn")
All_data <- All_data %>% select(all_of(vars))
#change name of Churn to Left
All_data <- All_data %>% rename(Left=Churn)
#change Left to numeric, make it 1 yes 0 no
All_data$Left[All_data$Left=="Yes"] <- 1
All_data$Left[All_data$Left=="No"] <- 0
All_data$Left <- as.numeric(All_data$Left)
# Drop rows with missing TotalCharges (customers with tenure=0 who were never charged)
All_data <- All_data %>% drop_na(TotalCharges)
# Convert Yes/No categorical variables to 0/1 numeric so data is ready to use
All_data <- All_data %>% rename(Male=gender)
All_data$Male          <- ifelse(All_data$Male == "Male", 1, 0)            # 1=Male, 0=Female
All_data$PhoneService  <- ifelse(All_data$PhoneService == "Yes", 1, 0)     # 1=Yes, 0=No
All_data$StreamingTV   <- ifelse(All_data$StreamingTV == "Yes", 1, 0)      # 1=Yes, 0=No
All_data$StreamingMovies <- ifelse(All_data$StreamingMovies == "Yes", 1, 0) # 1=Yes, 0=No
All_data$PaperlessBilling <- ifelse(All_data$PaperlessBilling == "Yes", 1, 0) # 1=Yes, 0=No
#now create 15 subsets randomly choosing 5000 observations WITHOUT replacement
set.seed(1234)
for (i in 1:15){
sample_data <- All_data %>% sample_n(5000, replace=FALSE)
save(sample_data, file=paste0("C:/Users/kzysi/Dropbox/Itam_teaching/Data/In_class_task1/Data/Prepared_data/student_data_",i,".Rda"))
}
path <- "C:/Users/kzysi/Dropbox/Itam_teaching/Data/In_class_task1/Data/Prepared_data/"
results_list <- list()
for (i in 1:15){
# load the dataset
load(paste0(path, "student_data_", i, ".Rda"))
r2_vals <- c()
coef_list <- list()
pred_vals <- c()
predictors <- setdiff(names(sample_data), c("customerID","Left"))
for (var in predictors){
f <- as.formula(paste("Left ~", var))
m <- lm(f, data = sample_data)
r2_vals[var] <- summary(m)$r.squared
coef_list[[var]] <- coef(m)
# prediction at median (continuous) or mode (binary/categorical)
# Binary 0/1 vars: use the most common category (mode)
binary_vars <- c("Male","SeniorCitizen","PhoneService","StreamingTV",
"StreamingMovies","PaperlessBilling")
if(var %in% binary_vars){
mode_val <- as.numeric(names(sort(table(sample_data[[var]]), decreasing=TRUE))[1])
newdat <- setNames(data.frame(mode_val), var)
pred_vals[var] <- predict(m, newdat)
} else if(is.numeric(sample_data[[var]])){
val <- median(sample_data[[var]], na.rm = TRUE)
newdat <- setNames(data.frame(val), var)
pred_vals[var] <- predict(m, newdat)
}
}
best_var <- names(which.max(r2_vals))
results_list[[i]] <- tibble(
dataset      = i,
best_var     = best_var,                                        # variable name
best_r2      = round(r2_vals[best_var], 4),                     # R^2
coefficients = paste(names(coef_list[[best_var]]),              # coefficients
round(coef_list[[best_var]], 3),
collapse = "; "),
pred_at_median = round(pred_vals[best_var], 3)                  # prediction
)
}
results_df <- bind_rows(results_list)
results_df
