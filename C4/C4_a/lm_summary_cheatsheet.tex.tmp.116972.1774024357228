\begin{minipage}[t]{0.24\textwidth}
\begin{greenbox}[title={Estimate}]
\small The coefficients themselves.\\[4pt]
$b_0 = 12.351$\\
$b_1 = 2.876$
\end{greenbox}
\end{minipage}
\hfill
\begin{minipage}[t]{0.24\textwidth}
\begin{orangebox}[title={Std.\ Error}]
\small How uncertain is each estimate.\\[4pt]
Smaller = more precise estimate.
\end{orangebox}
\end{minipage}
\hfill
\begin{minipage}[t]{0.24\textwidth}
\begin{tipbox}
{\bfseries\color{mypurple} t value}\\[3pt]
\small = Estimate / Std.Error\\[4pt]
Bigger $|t|$ = stronger evidence.
\end{tipbox}
\end{minipage}
\hfill
\begin{minipage}[t]{0.24\textwidth}
\begin{redbox}[title={Pr($>$$|$t$|$)}]
\small The \textbf{p-value}.\\[4pt]
