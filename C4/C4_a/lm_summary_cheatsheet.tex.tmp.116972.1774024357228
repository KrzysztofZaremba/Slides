\end{redbox}
\end{minipage}

\vspace{8pt}
\begin{orangebox}[title={\faStar\ \ What do the stars (***) mean?}]
\begin{center}
\texttt{***}\; $p < 0.001$ \qquad
\texttt{**}\; $p < 0.01$ \qquad
\texttt{*}\; $p < 0.05$ \qquad
\texttt{.}\; $p < 0.1$ \qquad
(blank)\; not significant
\end{center}
\vspace{2pt}
{\small\itshape More stars = stronger evidence that the variable matters. Our slope has \texttt{***}, so advertising clearly matters!}
\end{orangebox}

