% ── Section A: Residuals ──
\begin{sectionbox}{A}
A \quad Residuals
\end{sectionbox}

\begin{tcolorbox}[colback=lightblue, colframe=accentblue, arc=4pt, boxrule=1pt]
\textbf{Residuals = Actual Sales $-$ Predicted Sales} (the errors of your model).\\[3pt]
The five-number summary (Min, Q1, Median, Q3, Max) tells you how spread out the errors are.\\[3pt]
{\bfseries\color{mygreen} What to look for:} Median close to 0 is good (errors are balanced). Here: 0.381 --- nicely centered.
\end{tcolorbox}

% ── Section B: Coefficients ──
\begin{sectionbox}{B}
B \quad Coefficients Table \normalfont\normalsize\color{white!80}(the core of the output)
